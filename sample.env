# Security - change these in production!
FLASK_DEBUG=false
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-value
ADMIN_BOOTSTRAP_PASSWORD=change-me-first-boot
FLASK_CSRF=true
FLASK_SECURE_COOKIES=true

# Telegram Bot Configuration (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_SECRET=

# Admin API Key (required for /api/* endpoints)
ADMIN_API_KEY=

# MCP admin server
MCP_API_KEY=
MCP_SERVER_ENABLED=false
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8765
